// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  slug         String?  @unique
  passwordHash String?  @map("password_hash")
  displayName  String   @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  city         String?
  state        String?  @default("UT")
  isAdmin            Boolean  @default(false) @map("is_admin")
  crownJewelMedalId  String?  @map("crown_jewel_medal_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  accounts             Account[]
  medals               Medal[]
  submittedRestaurants Restaurant[]         @relation("SubmittedRestaurants")
  submittedLinks       RestaurantCategory[] @relation("SubmittedLinks")
  suggestionVotes      SuggestionVote[]
  categorySuggVotes    CategorySuggestionVote[]
  newCategorySuggestions     NewCategorySuggestion[]      @relation("NewCategorySuggestions")
  newCategorySuggestionVotes NewCategorySuggestionVote[]
  addressReports             AddressReport[]
  goldMedalComments          GoldMedalComment[]
  commentUpvotes             CommentUpvote[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Restaurant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  address     String
  city        String
  state       String   @default("UT")
  zip         String
  lat         Float?
  lng         Float?
  description String?
  websiteUrl  String?  @map("website_url")
  imageUrl    String?  @map("image_url")
  status      String   @default("active") // active | pending_review | inactive
  submittedBy String?  @map("submitted_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  submitter       User?                @relation("SubmittedRestaurants", fields: [submittedBy], references: [id])
  categories      RestaurantCategory[]
  medals          Medal[]
  suggestionVotes    SuggestionVote[]
  categorySuggVotes  CategorySuggestionVote[]
  addressReports     AddressReport[]
  goldMedalComments  GoldMedalComment[]

  @@index([status, city, state])
  @@map("restaurants")
}

model FoodCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  iconEmoji   String   @map("icon_emoji")
  iconUrl     String?  @map("icon_url")
  description String?
  parentId    String?  @map("parent_id")
  sortOrder   Int      @default(0) @map("sort_order")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")

  parent      FoodCategory?        @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    FoodCategory[]       @relation("CategoryHierarchy")
  restaurants        RestaurantCategory[]
  medals             Medal[]
  categorySuggVotes  CategorySuggestionVote[]
  goldMedalComments  GoldMedalComment[]

  @@map("food_categories")
}

model RestaurantCategory {
  id             String   @id @default(cuid())
  restaurantId   String   @map("restaurant_id")
  foodCategoryId String   @map("food_category_id")
  submittedBy    String?  @map("submitted_by")
  verified       Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id])
  foodCategory FoodCategory @relation(fields: [foodCategoryId], references: [id])
  submitter    User?        @relation("SubmittedLinks", fields: [submittedBy], references: [id])

  @@unique([restaurantId, foodCategoryId])
  @@index([foodCategoryId, verified])
  @@map("restaurant_categories")
}

model Medal {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  foodCategoryId String   @map("food_category_id")
  restaurantId   String   @map("restaurant_id")
  medalType      String   @map("medal_type") // gold | silver | bronze
  year           Int
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user              User              @relation(fields: [userId], references: [id])
  foodCategory      FoodCategory      @relation(fields: [foodCategoryId], references: [id])
  restaurant        Restaurant        @relation(fields: [restaurantId], references: [id])
  goldMedalComment  GoldMedalComment?

  @@unique([userId, foodCategoryId, medalType, year])
  @@index([foodCategoryId, year])
  @@index([restaurantId, year])
  @@index([userId, year])
  @@map("medals")
}

model SuggestionVote {
  id           String   @id @default(cuid())
  restaurantId String   @map("restaurant_id")
  userId       String   @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, userId])
  @@map("suggestion_votes")
}

model CategorySuggestionVote {
  id             String   @id @default(cuid())
  restaurantId   String   @map("restaurant_id")
  foodCategoryId String   @map("food_category_id")
  userId         String   @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  foodCategory FoodCategory @relation(fields: [foodCategoryId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, foodCategoryId, userId])
  @@map("category_suggestion_votes")
}

model NewCategorySuggestion {
  id          String   @id @default(cuid())
  name        String
  iconEmoji   String   @map("icon_emoji")
  description String?
  submittedBy String   @map("submitted_by")
  status      String   @default("pending") // pending | approved | rejected
  createdAt   DateTime @default(now()) @map("created_at")

  submitter User                       @relation("NewCategorySuggestions", fields: [submittedBy], references: [id], onDelete: Cascade)
  votes     NewCategorySuggestionVote[]

  @@map("new_category_suggestions")
}

model NewCategorySuggestionVote {
  id           String   @id @default(cuid())
  suggestionId String   @map("suggestion_id")
  userId       String   @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  suggestion NewCategorySuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([suggestionId, userId])
  @@map("new_category_suggestion_votes")
}

model AddressReport {
  id            String   @id @default(cuid())
  restaurantId  String   @map("restaurant_id")
  userId        String   @map("user_id")
  googleMapsUrl String?  @map("google_maps_url")
  note          String?
  status        String   @default("pending") // pending | resolved | dismissed
  createdAt     DateTime @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, userId])
  @@map("address_reports")
}

model GoldMedalComment {
  id             String   @id @default(cuid())
  medalId        String?  @unique @map("medal_id")
  userId         String   @map("user_id")
  restaurantId   String   @map("restaurant_id")
  foodCategoryId String   @map("food_category_id")
  year           Int
  comment        String   @db.Text
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  medal        Medal?       @relation(fields: [medalId], references: [id], onDelete: SetNull)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  foodCategory FoodCategory @relation(fields: [foodCategoryId], references: [id], onDelete: Cascade)
  upvotes      CommentUpvote[]

  @@unique([userId, foodCategoryId, restaurantId, year])
  @@index([restaurantId, active])
  @@index([userId])
  @@map("gold_medal_comments")
}

model CommentUpvote {
  id        String   @id @default(cuid())
  commentId String   @map("comment_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  comment GoldMedalComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("comment_upvotes")
}
